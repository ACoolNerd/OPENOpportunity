# ─── Firebase (client-side — safe to expose via NEXT_PUBLIC_) ────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ─── Square (server-side only — NEVER prefix with NEXT_PUBLIC_) ───────────────
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=sandbox

# ─── QuickBooks Online (server-side only) ─────────────────────────────────────
QB_CLIENT_ID=your_qb_client_id
QB_CLIENT_SECRET=your_qb_client_secret
QB_REFRESH_TOKEN=your_qb_refresh_token
QB_REALM_ID=your_qb_realm_id
QB_ENVIRONMENT=sandbox
