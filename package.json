{
  "name": "open-opportunity",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "build:motion": "esbuild src/hero-motion.js --bundle --minify --format=iife --outfile=public/hero-motion.js",
